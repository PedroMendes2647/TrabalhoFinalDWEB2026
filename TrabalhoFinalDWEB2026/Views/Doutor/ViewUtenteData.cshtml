@model TrabalhoFinalDWEB2026.Models.Utente

@{
    ViewData["Title"] = "Dados do Paciente";
    var utente = ViewBag.Utente as TrabalhoFinalDWEB2026.Models.Utente;
    var receitas = ViewBag.Receitas as List<TrabalhoFinalDWEB2026.Models.Receita>;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <a href="@Url.Action("SearchUtente")" class="btn btn-secondary mb-3">
                <i class="bi bi-arrow-left"></i> Voltar à Pesquisa
            </a>
        </div>
    </div>

    @if (utente != null)
    {
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card border-success">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0">
                            <i class="bi bi-person"></i> Dados do Paciente
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Nome:</strong>
                                <p>@utente.Nome</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Número de Utente:</strong>
                                <p>@utente.NumeroUtente</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Email:</strong>
                                <p>@utente.Email</p>
                            </div>
                            <div class="col-md-6">
                                <strong>Data de Nascimento:</strong>
                                <p>@utente.DataNascimento.ToString("dd/MM/yyyy")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-success">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Ações</h5>
                    </div>
                    <div class="card-body d-grid gap-2">
                        <a href="@Url.Action("CreateReceita", "Doutor", new { utenteId = utente.Id })" 
                           class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Criar Receita
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-file-text"></i> Receitas Médicas
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (receitas != null && receitas.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>ID</th>
                                            <th>Data de Emissão</th>
                                            <th>Estado</th>
                                            <th>Data de Dispensação</th>
                                            <th>Medicamentos</th>
                                            <th>Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var receita in receitas)
                                        {
                                            <tr>
                                                <td>#@receita.Id</td>
                                                <td>@receita.DataEmissao.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    @if (receita.Estado == "Emitida")
                                                    {
                                                        <span class="badge bg-warning text-dark">Emitida</span>
                                                    }
                                                    else if (receita.Estado == "Aviada")
                                                    {
                                                        <span class="badge bg-success">Aviada</span>
                                                    }
                                                    else if (receita.Estado == "Expirada")
                                                    {
                                                        <span class="badge bg-danger">Expirada</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@receita.Estado</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (receita.DataDispensacao.HasValue)
                                                    {
                                                        <text>@receita.DataDispensacao.Value.ToString("dd/MM/yyyy HH:mm")</text>
                                                    }
                                                    else
                                                    {
                                                        <text>-</text>
                                                    }
                                                </td>
                                                <td>
                                                    @if (receita.ListaDeMedicamentos != null && receita.ListaDeMedicamentos.Count > 0)
                                                    {
                                                        <small>@receita.ListaDeMedicamentos.Count medicamento(s)</small>
                                                    }
                                                    else
                                                    {
                                                        <small class="text-muted">Nenhum</small>
                                                    }
                                                </td>
                                                <td>
                                                    <a href="#" class="btn btn-sm btn-info" title="Ver Detalhes">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    @if (receita.Estado != "Aviada")
                                                    {
                                                        <form method="post" action="@Url.Action("DeleteReceita", "Doutor")" style="display:inline;">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="receitaId" value="@receita.Id" />
                                                            <input type="hidden" name="utenteId" value="@utente.Id" />
                                                            <button type="submit" class="btn btn-sm btn-danger" title="Deletar Receita" onclick="return confirm('Tem a certeza que deseja deletar esta receita?');">
                                                                <i class="bi bi-trash"></i> Apagar
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary" disabled title="Não pode apagar receitas aviadas">
                                                            <i class="bi bi-trash"></i> Apagar
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> Este paciente não possui receitas registadas.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-circle"></i> Dados do paciente não estão disponíveis.
        </div>
    }
</div>

<style>
    .card {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>
