@model TrabalhoFinalDWEB2026.Controllers.CreateReceitaModel

@{
    ViewData["Title"] = "Criar Receita";
    var medicamentos = ViewBag.Medicamentos as List<TrabalhoFinalDWEB2026.Models.Medicamentos> ?? new();
    var utenteId = ViewBag.UtenteId;
    var utenteName = ViewBag.UtenteName;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <a href="@Url.Action("SearchUtente")" class="btn btn-secondary mb-3">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>

            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-file-text"></i> Criar Nova Receita
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <strong>Paciente:</strong> @utenteName
                    </div>

                    <form method="post" asp-action="CreateReceita" asp-route-utenteId="@utenteId">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <h5>Selecione Medicamentos</h5>
                            <div class="card p-3 bg-light">
                                @if (medicamentos.Count > 0)
                                {
                                    @foreach (var med in medicamentos)
                                    {
                                        <div class="card mb-3">
                                            <div class="card-body">
                                                <div class="form-check">
                                                    <input class="form-check-input medicamento-checkbox" 
                                                           type="checkbox" 
                                                           name="MedicamentoIds" 
                                                           value="@med.Id" 
                                                           id="med_@med.Id"
                                                           onchange="toggleMedicamentDetails(this)">
                                                    <label class="form-check-label" for="med_@med.Id">
                                                        <strong>@med.Nome</strong> - @med.Dosagem (@med.Tipo)
                                                    </label>
                                                </div>
                                                <div id="details_@med.Id" class="mt-3" style="display: none;">
                                                    <div class="row">
                                                            <div class="col-md-6">
                                                                <label for="qtd_@med.Id" class="form-label">Quantidade</label>
                                                                <input type="number" 
                                                                       id="qtd_@med.Id" 
                                                                       name="Quantidades" 
                                                                       class="form-control" 
                                                                       min="1" 
                                                                       max="10" 
                                                                       value="1">
                                                            </div>
                                                        </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted">Nenhum medicamento disponível</p>
                                }
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Criar Receita
                            </button>
                            <a href="@Url.Action("ViewUtenteData", "Doutor", new { utenteId = utenteId })" 
                               class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    .medicamento-checkbox {
        cursor: pointer;
    }

    .card-body input[type="text"],
    .card-body input[type="number"] {
        font-size: 0.9rem;
    }
</style>

<script>
    function toggleMedicamentDetails(checkbox) {
        const medicamentId = checkbox.value;
        const detailsElement = document.getElementById('details_' + medicamentId);
        if (checkbox.checked) {
            detailsElement.style.display = 'block';
        } else {
            detailsElement.style.display = 'none';
        }
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
