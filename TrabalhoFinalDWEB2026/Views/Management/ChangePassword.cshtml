@model TrabalhoFinalDWEB2026.Controllers.ChangePasswordModel

@{
    ViewData["Title"] = "Alterar Palavra-passe";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Alterar Palavra-passe</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-bold">Palavra-passe Atual</label>
                            <input asp-for="CurrentPassword" type="password" class="form-control" required />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-bold">Nova Palavra-passe</label>
                            <input asp-for="NewPassword" type="password" class="form-control" required />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            <small class="text-muted">
                                A palavra-passe deve ter pelo menos 6 caracteres, incluindo maiúsculas, minúsculas, números e caracteres especiais.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirmar Palavra-passe</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Alterar Palavra-passe</button>
                            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
