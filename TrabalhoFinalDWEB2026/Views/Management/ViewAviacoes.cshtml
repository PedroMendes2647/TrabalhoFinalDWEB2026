@model IEnumerable<TrabalhoFinalDWEB2026.Models.Receita>

@{
    ViewData["Title"] = "Aviações de Receita";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Aviações de Receita</h1>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-success">
                            <tr>
                                <th>ID</th>
                                <th>Data de Emissão</th>
                                <th>Data de Dispensação</th>
                                <th>Utente</th>
                                <th>Doutor</th>
                                <th>Farmacêutico</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var receita in Model)
                            {
                                <tr>
                                    <td>@receita.Id</td>
                                    <td>@receita.DataEmissao.ToString("dd/MM/yyyy")</td>
                                    <td>@(receita.DataDispensacao.HasValue ? receita.DataDispensacao.Value.ToString("dd/MM/yyyy") : "-")</td>
                                    <td>@(receita.Utente?.Nome ?? "N/A")</td>
                                    <td>@(receita.DoutorUtente?.Nome ?? "N/A")</td>
                                    <td>@(receita.FarmaceutaUtente?.Nome ?? "N/A")</td>
                                    <td>
                                        <a href="@Url.Action("ReceitaDetails", "Management", new { receitaId = receita.Id })" class="btn btn-sm btn-info">Ver Detalhes</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Nenhuma receita aviada encontrada.
                </div>
            }

            <div class="mt-4">
                <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-secondary">Voltar ao Painel</a>
            </div>
        </div>
    </div>
</div>
