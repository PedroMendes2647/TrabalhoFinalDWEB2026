@model IEnumerable<TrabalhoFinalDWEB2026.Models.Utente>

@{
    ViewData["Title"] = "Lista de Utentes";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Lista de Utentes</h1>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th>Número de Utente</th>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Data de Nascimento</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var utente in Model)
                            {
                                <tr>
                                    <td>@utente.NumeroUtente</td>
                                    <td>@utente.Nome</td>
                                    <td>@utente.Email</td>
                                    <td>@utente.DataNascimento.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <a href="@Url.Action("ViewUtenteProfile", "Management", new { utenteId = utente.Id })" class="btn btn-sm btn-info">Ver Perfil</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Nenhum utente encontrado.
                </div>
            }

            <div class="mt-4">
                <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-secondary">Voltar ao Painel</a>
            </div>
        </div>
    </div>
</div>
